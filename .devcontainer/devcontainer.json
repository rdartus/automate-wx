{
    "name": "Playwright Scraper",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "remoteUser": "root",
    "forwardPorts": [6080],
    "features": {
        "desktop-lite": {
        "webPort": "6080"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-playwright.playwright",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "eamodio.gitlens"
            ]
        }
    },

    "postCreateCommand": "npm install",

    "containerEnv": {
        "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright"
    },

    "remoteEnv": {
        "SITE_URL": "${localEnv:SITE_URL}",
        "USER_WX": "${localEnv:USER_WX}",
        "PASSWORD_WX": "${localEnv:PASSWORD_WX}"
    }
}